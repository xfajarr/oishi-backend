{
  "name": "oishi-backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node20 --outfile=api/_bundle.mjs --external:@solana/web3.js --external:@coral-xyz/anchor",
    "typecheck": "tsc --noEmit",
    "start": "node api/_bundle.mjs"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@hono/node-server": "^1.19.14",
    "@noble/ed25519": "^3.1.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.105.4",
    "bs58": "^6.0.0",
    "hono": "^4.12.18",
    "jose": "^6.2.3",
    "openai": "^6.37.0",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "esbuild": "^0.25.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
