# ─── Oishi Agent Backend ────────────────────────────────────────────────

# Port the server listens on
PORT=3001

# ── LLM Provider (OpenAI-compatible SDK) ────────────────────────────────
# Set ALL three for your provider — works with fetch.ai, tokenrouter,
# OpenAI, Anthropic via proxy, or any OpenAI-compatible endpoint.
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ── Agent Scheduler ─────────────────────────────────────────────────────
# How often the scheduler wakes all active agents (in milliseconds)
AGENT_CYCLE_MS=60000
# How often data is persisted to disk (in milliseconds)
PERSIST_MS=30000

# ── Development ─────────────────────────────────────────────────────────
# Set to 1 to bypass Solana wallet signature verification (local dev only)
OISHI_DEV_MODE=0

# ── Storage ─────────────────────────────────────────────────────────────
# No database needed — agents and contexts are auto-saved as JSON files
# in src/data/agents.json and src/data/contexts.json.
# In-memory during runtime, persisted on every write + periodic snapshots.
