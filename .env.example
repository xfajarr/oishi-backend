# ─── Oishi Agent Backend ────────────────────────────────────────────────

PORT=3001

# ── LLM Provider (OpenAI-compatible) ────────────────────────────────────
LLM_API_KEY=sk-your-key-here
# Must be the API root with /v1 (e.g. https://api.openai.com/v1). If you omit /v1, it is appended automatically.
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# If chat returns HTTP 400 with no body, your provider may not support function calling — set 1 to disable tools for testing.
# LLM_DISABLE_TOOLS=1

# ── JWT Session Tokens ──────────────────────────────────────────────────
# Secret for signing session JWTs (change in production, min 32 chars)
JWT_SECRET=oishi-dev-secret-change-in-production-min-32-chars
# Token expiry (e.g. 7d, 24h, 1h)
JWT_EXPIRY=7d

# ── Supabase (optional — falls back to JSON files if not set) ───────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGciOi...

# ── Agent Scheduler ─────────────────────────────────────────────────────
AGENT_CYCLE_MS=60000
PERSIST_MS=30000

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
# LOG_FILE=logs/backend.log

# ── Development ─────────────────────────────────────────────────────────
OISHI_DEV_MODE=0
